{
  "name": "@nuintun/svgo-loader",
  "version": "0.6.0",
  "description": "svgo loader for webpack.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./esm/webpack/index.js",
      "require": "./cjs/webpack/index.cjs",
      "default": "./esm/webpack/index.js"
    },
    "./rspack": {
      "import": "./esm/rspack/index.js",
      "require": "./cjs/rspack/index.cjs",
      "default": "./esm/rspack/index.js"
    }
  },
  "files": [
    "cjs",
    "esm"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuintun/svgo-loader.git"
  },
  "keywords": [
    "svgo",
    "loader",
    "rspack",
    "webpack"
  ],
  "author": {
    "name": "nuintun",
    "email": "nuintun@qq.com"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nuintun/svgo-loader/issues"
  },
  "homepage": "https://github.com/nuintun/svgo-loader#readme",
  "scripts": {
    "lint": "tsc --noEmit",
    "pretest": "pnpm build",
    "clean": "node tools/clean.ts",
    "prepublishOnly": "pnpm build",
    "test": "node tests/rspack.config.ts",
    "build:cjs": "rollup -c tools/rollup.cjs.ts",
    "build:esm": "rollup -c tools/rollup.esm.ts",
    "build:fix-types": "node tools/fix-types.ts",
    "build": "pnpm clean && pnpm build:main && pnpm format",
    "format": "prettier --write . --ignore-path .prettierignore",
    "build:main": "pnpm build:cjs && pnpm build:esm && pnpm build:fix-types"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@rspack/core": "^1.7.11",
    "@types/node": "^25.6.0",
    "dts-paths": "^2.2.1",
    "prettier": "^3.8.2",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.1",
    "svgo": "^4.0.1",
    "typescript": "^6.0.2",
    "webpack": "^5.106.1"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.0",
    "svgo": "^4.0.0",
    "webpack": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  }
}
